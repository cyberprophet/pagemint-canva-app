{
  "$schema": "https://www.canva.dev/schemas/app-manifest.json",
  "id": "pagemint-canva-app",
  "name": "PageMint",
  "description": "Import your completed PageMint designs into Canva as images.",
  "type": "content_extension",
  "content": {
    "types": ["image"],
    "search": {
      "endpoint": "/api/canva/resources/find"
    }
  },
  "permissions": [
    "canva:design:read",
    "canva:design:write"
  ],
  "icon": "assets/icon.png"
}
